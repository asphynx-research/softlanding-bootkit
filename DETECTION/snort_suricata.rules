# SOFTLANDING / TeamPCP — Snort/Suricata Network Detection Rules
# Author: ASPHYNX — June 2026

# ─── C2 DOMAIN DNS QUERIES ───
alert dns $HOME_NET any -> any any (msg:"SOFTLANDING - TeamPCP C2 DNS Query (t.m-kosche.com)"; dns_query; content:"t.m-kosche.com"; nocase; classtype:trojan-activity; sid:20260001; rev:1;)
alert dns $HOME_NET any -> any any (msg:"SOFTLANDING - Session P2P C2 Fallback DNS Query"; dns_query; content:"filev2.getsession.org"; nocase; classtype:trojan-activity; sid:20260002; rev:1;)
alert dns $HOME_NET any -> any any (msg:"SOFTLANDING - TanStack C2 DNS Query"; dns_query; content:"git-tanstack.com"; nocase; classtype:trojan-activity; sid:20260003; rev:1;)

# ─── C2 TRAFFIC TO KNOWN IPs ───
alert tcp $HOME_NET any -> 83.142.209.0/24 any (msg:"SOFTLANDING - TeamPCP C2 Subnet Traffic"; flow:to_server,established; classtype:trojan-activity; sid:20260010; rev:1;)
alert tcp $HOME_NET any -> 185.95.159.32 any (msg:"SOFTLANDING - TeamPCP C2 IP Traffic"; flow:to_server,established; classtype:trojan-activity; sid:20260011; rev:1;)
alert tcp $HOME_NET any -> 85.209.11.79 any (msg:"SOFTLANDING - APT Infrastructure"; flow:to_server,established; classtype:trojan-activity; sid:20260012; rev:1;)

# ─── PROXY RELAY LAYER (sample — use full list from iocs/) ───
alert tcp $HOME_NET any -> [190.153.121.2,177.101.135.89,77.75.230.115,103.113.71.230,68.71.254.6] any (msg:"SOFTLANDING - Proxy Relay Layer Traffic"; flow:to_server,established; classtype:trojan-activity; sid:20260020; rev:1;)

# ─── DEADMAN SWITCH TOKEN IN HTTP ───
alert tcp $HOME_NET any -> any 443 (msg:"SOFTLANDING - Deadman Switch Token in HTTPS"; flow:to_server,established; content:"IfYouRevokeThisTokenItWillWipeTheComputerOfTheOwner"; nocase; classtype:trojan-activity; sid:20260030; rev:1;)

# ─── SHAI-HULUD GITHUB DEAD-DROP ACCESS ───
alert tcp $HOME_NET any -> any 443 (msg:"SOFTLANDING - Shai-Hulud GitHub Dead-Drop Pattern"; flow:to_server,established; content:"Sha1-Hulud"; nocase; classtype:trojan-activity; sid:20260040; rev:1;)
alert tcp $HOME_NET any -> any 443 (msg:"SOFTLANDING - Goldox-T3chs Dead-Drop Pattern"; flow:to_server,established; content:"Goldox-T3chs"; nocase; classtype:trojan-activity; sid:20260041; rev:1;)

# ─── CRYPTO MINING POOL TRAFFIC ───
alert tcp $HOME_NET any -> any 443 (msg:"SOFTLANDING - Stratum Mining Protocol"; flow:to_server,established; content:"stratum"; nocase; depth:10; classtype:policy-violation; sid:20260050; rev:1;)
alert tcp $HOME_NET any -> any 443 (msg:"SOFTLANDING - XMRig Mining Agent"; flow:to_server,established; content:"XMRig"; nocase; classtype:policy-violation; sid:20260051; rev:1;)

# ─── UNUSUAL GPU ACCESS PATTERNS ───
alert tcp $HOME_NET any -> any any (msg:"SOFTLANDING - Ollama API GPU Abuse Pattern"; flow:to_server,established; content:"ollama"; nocase; http_uri; classtype:policy-violation; sid:20260060; rev:1;)
